# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
.venv-py312/
venv/

# Environment
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code local settings (per-developer permission overrides)
.claude/settings.local.json

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Project data (local only)
logs/
replays/
# Legacy root-level data/ — leave fully ignored (audit snapshots, backups).
# Scoped to the root so `bots/*/data/` below can use negation for tracked
# config files.
/data/
# Snapshot/backup parent dir — operator manual snapshots
# (data-pre-soak-*, data-post-soak-*) and skill-auto backups
# (data.bak-*, data.demo-snapshot-*) all live here. README is tracked so
# the convention is documented; everything else is gitignored.
/data-snapshots/*
!/data-snapshots/README.md

# Versioned bot data (Step 1.8+) — runtime state ignored, config tracked.
/bots/*/data/**
!/bots/*/data/hyperparams.json
!/bots/*/data/reward_rules.json

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/build/

# mypy
.mypy_cache/

# pytest
.pytest_cache/

# ruff
.ruff_cache/
.ui-review-evidence/
.ui-dashboard-evidence/

# Raw capture files — only cropped/optimized GIFs should be committed in documentation/images/
documentation/images/*.mp4
documentation/images/*.mov
